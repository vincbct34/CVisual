# Database
DATABASE_URL="postgresql://cvisual:cvisual@localhost:5432/cvisual?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend (password-reset emails — /api/auth/forgot-password)
RESEND_API_KEY=""
RESEND_FROM="CVisual <noreply@yourdomain.com>"

# Rate limiting (optional). When both are set, throttling uses Upstash Redis
# (shared across instances — required for real enforcement on Vercel/Lambda).
# If unset, falls back to a single-instance in-memory limiter. See src/lib/rate-limit.ts.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
